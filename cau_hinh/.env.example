# ============================================
# YouTube China Pipeline - Environment Config
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ---- OpenAI (ChatGPT rewrite) ----
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ---- ElevenLabs (Voice AI) ----
ELEVENLABS_API_KEY=your-key-here
ELEVENLABS_VOICE_ID=your-voice-id

# ---- YouTube Data API ----
YOUTUBE_API_KEY=your-key-here
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret

# ---- DeepL Translate ----
DEEPL_API_KEY=your-key-here

# ---- Fish Audio ----
FISH_AUDIO_API_KEY=your-key-here

# ---- Edge TTS (no key needed) ----
EDGE_TTS_VOICE=vi-VN-HoaiMyNeural

# ---- Paths ----
SOURCE_DIR=./01_sources
SCRIPTS_DIR=./02_scripts
VOICE_DIR=./03_voiceover
EDIT_DIR=./04_editing
SUBTITLE_DIR=./05_subtitles
THUMB_DIR=./06_thumbnails
OUTPUT_DIR=./07_output
PUBLISHED_DIR=./08_published
DATA_DIR=./09_data
AUTO_DIR=./10_automation
